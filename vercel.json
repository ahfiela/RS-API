{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1",
      "config": { "maxDuration": 30 }
    }
  },
  "routes": [
    {
      "src": "/_vercel/image(.*)",
      "dest": "/_vercel/image$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
